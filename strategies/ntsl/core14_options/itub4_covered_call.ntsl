// Arbitragem Core17 — itub4_covered_call
// Structure: covered call · Buy stock then Sell OTM call
// Underlying: ITUB4
input
  StopTicks(4);
  TargetTicks(7);
var
  EntryPrice : Float;
begin
  EntryPrice := Close;
// scalp ITUB4 — Buy stock then Sell OTM call
// BuyAtMarket(100, "ITUB4");
  SetStopLoss(StopTicks * MinPriceIncrement);
  SetProfitTarget(TargetTicks * MinPriceIncrement);
end;
