// Arbitragem Core17 — b3sa3_collar
// Structure: collar · Long stock + protective put + short call
// Underlying: B3SA3
input
  StopTicks(6);
  TargetTicks(8);
var
  EntryPrice : Float;
begin
  EntryPrice := Close;
// Leg 1: long B3SA3
