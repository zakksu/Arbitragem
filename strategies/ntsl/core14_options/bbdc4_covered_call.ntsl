// Arbitragem Core17 — bbdc4_covered_call
// Structure: covered call · Buy stock then Sell OTM call
// Underlying: BBDC4
input
  StopTicks(4);
  TargetTicks(10);
var
  EntryPrice : Float;
begin
  EntryPrice := Close;
// scalp BBDC4 — Buy stock then Sell OTM call
// BuyAtMarket(100, "BBDC4");
  SetStopLoss(StopTicks * MinPriceIncrement);
  SetProfitTarget(TargetTicks * MinPriceIncrement);
end;
