// Arbitragem Core17 — prio3_collar
// Structure: collar · Long stock + protective put + short call
// Underlying: PRIO3
input
  StopTicks(6);
  TargetTicks(11);
var
  EntryPrice : Float;
begin
  EntryPrice := Close;
// Leg 1: long PRIO3
// BuyAtMarket(100, "PRIO3");
// Leg 2: protective put
// BuyAtMarket(1, "PRIOM380");
// Leg 3: short OTM call
// SellAtMarket(1, "PRIOA400");
  SetStopLoss(StopTicks * MinPriceIncrement);
  SetProfitTarget(TargetTicks * MinPriceIncrement);
end;
