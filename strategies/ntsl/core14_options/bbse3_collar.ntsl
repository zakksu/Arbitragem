// Arbitragem Core17 — bbse3_collar
// Structure: collar · Long stock + protective put + short call
// Underlying: BBSE3
input
  StopTicks(6);
  TargetTicks(10);
var
  EntryPrice : Float;
begin
  EntryPrice := Close;
// Leg 1: long BBSE3
// BuyAtMarket(100, "BBSE3");
// Leg 2: protective put
// BuyAtMarket(1, "BBSEM210");
// Leg 3: short OTM call
// SellAtMarket(1, "BBSEA220");
  SetStopLoss(StopTicks * MinPriceIncrement);
  SetProfitTarget(TargetTicks * MinPriceIncrement);
end;
