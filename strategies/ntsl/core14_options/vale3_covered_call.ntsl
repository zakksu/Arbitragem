// Arbitragem Core17 — vale3_covered_call
// Structure: covered call · Buy stock then Sell OTM call
// Underlying: VALE3
input
  StopTicks(4);
  TargetTicks(11);
var
  EntryPrice : Float;
begin
  EntryPrice := Close;
// scalp VALE3 — Buy stock then Sell OTM call
// BuyAtMarket(100, "VALE3");
  SetStopLoss(StopTicks * MinPriceIncrement);
  SetProfitTarget(TargetTicks * MinPriceIncrement);
end;
