// Arbitragem Core17 — itub4_collar
// Structure: collar · Long stock + protective put + short call
// Underlying: ITUB4
input
  StopTicks(6);
  TargetTicks(9);
var
  EntryPrice : Float;
begin
  EntryPrice := Close;
// Leg 1: long ITUB4
// BuyAtMarket(100, "ITUB4");
// Leg 2: protective put
// BuyAtMarket(1, "ITUBM320");
// Leg 3: short OTM call
// SellAtMarket(1, "ITUBA340");
  SetStopLoss(StopTicks * MinPriceIncrement);
  SetProfitTarget(TargetTicks * MinPriceIncrement);
end;
