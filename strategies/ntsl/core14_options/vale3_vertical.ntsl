// Arbitragem Core17 — vale3_vertical
// Structure: vertical · Bull call vertical spread
// Underlying: VALE3
input
  StopTicks(5);
  TargetTicks(12);
var
  EntryPrice : Float;
begin
  EntryPrice := Close;
// Leg 1: buy lower strike call on VALE3
// BuyAtMarket(1, "VALEA680");
// Leg 2: sell higher strike call
// SellAtMarket(1, "VALEA680");
  SetStopLoss(StopTicks * MinPriceIncrement);
  SetProfitTarget(TargetTicks * MinPriceIncrement);
end;
