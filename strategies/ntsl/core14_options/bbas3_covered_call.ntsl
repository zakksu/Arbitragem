// Arbitragem Core17 — bbas3_covered_call
// Structure: covered call · Buy stock then Sell OTM call
// Underlying: BBAS3
input
  StopTicks(4);
  TargetTicks(12);
var
  EntryPrice : Float;
begin
  EntryPrice := Close;
// scalp BBAS3 — Buy stock then Sell OTM call
// BuyAtMarket(100, "BBAS3");
  SetStopLoss(StopTicks * MinPriceIncrement);
  SetProfitTarget(TargetTicks * MinPriceIncrement);
end;
