// Arbitragem 13.0 — VWAP reclaim long
// Close > VWAP after dip
// Symbol: set in Profit Replay / Editor
Input
  StopTicks(4);
  TargetTicks(6);
Var
  vwap : Float;
Begin
  vwap := VWAP(1);
  // Entry: pattern-specific — arm on replay for PETR4|VALE3|ITUB4|BOVA11|PRIO3
  // Stop: StopTicks * tick from entry
  // Target: TargetTicks * tick
  Plot(vwap);
End.
