// Arbitragem 13.0 — Afternoon trend
// 14:00+ with BOVA bias
// Symbol: set in Profit Replay / Editor
Input
  StopTicks(70);
  TargetTicks(110);
Var
  vwap : Float;
Begin
  vwap := VWAP(1);
// CrossOrder(true); // enable in Profit for WINFUT
  // Entry: pattern-specific — arm on replay for WINFUT
  // Stop: StopTicks * tick from entry
  // Target: TargetTicks * tick
  Plot(vwap);
End.
