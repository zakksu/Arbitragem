# =============================================================================
# Arbitragem Dashboard — Environment Variables
# Copy to .env and fill in your values
# =============================================================================

# App
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-long-random-string
LOG_LEVEL=INFO
TIMEZONE=America/Sao_Paulo

# Database (SQLite default; switch to PostgreSQL for production VPS)
DATABASE_URL=sqlite:///./data/arbitragem.db
# DATABASE_URL=postgresql://arbitragem:password@db:5432/arbitragem

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000

# Streamlit
STREAMLIT_PORT=8501

# Ollama (local or remote VPS)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_PROBE_TIMEOUT_SECONDS=1.5
OLLAMA_ENABLED=true
# false = faster scans (Ollama only on-demand via Ask Ollama button)
SCANNER_OLLAMA_ON_SCAN=false

# Clear Corretora Smart Trader API
CLEAR_API_BASE_URL=https://api.clear.com.br/smarttrader
CLEAR_API_KEY=
CLEAR_API_SECRET=
CLEAR_ACCOUNT_ID=

# ProfitChart / ProfitDLL (Windows bridge — see docs/profit_bridge.md)
PROFIT_BRIDGE_ENABLED=true
PROFIT_BRIDGE_AUTO_DETECT=true
PROFIT_BRIDGE_URL=http://localhost:9100
PROFIT_DLL_PATH=C:/Nelogica/Profit/ProfitDLL.dll
PROFIT_EXPORT_DIR=./exports/profit
# ProfitChart accounts — same password for all; pick active via PAPER_TRADING_MODE + PROFIT_LIVE_STYLE
PROFIT_PASSWORD=
PROFIT_ACCOUNT_SIM_ID=3368
PROFIT_ACCOUNT_SIM_NAME=Filipe
PROFIT_ACCOUNT_DAY_ID=14852883
PROFIT_ACCOUNT_SWING_ID=14852883
PROFIT_ACCOUNT_LIVE_NAME=Filipe G. Monteiro
# day | swing — only when PAPER_TRADING_MODE=false
PROFIT_LIVE_STYLE=day

# PROFITCHART_EXE=C:/Nelogica/Profit/ProfitChart.exe
PROFITCHART_CO_START=true

# 13.0 — Core5 desk (PETR4 VALE3 ITUB4 BOVA11 PRIO3 + WIN/WDO)
SCANNER_MODE=filipe_core5
SCANNER_SYMBOLS=PETR4,VALE3,ITUB4,BOVA11,PRIO3
AUTONOMY_MAX_TRADES_PER_DAY=0
LIVE_CAPITAL_BRL=1000
PHASE_C_SIGNED_OFF=false
PROFIT_WIN_CROSS_ORDER=true

# Risk limits (defaults — overridable per strategy in dashboard)
DEFAULT_DAILY_LOSS_LIMIT_BRL=100
DEFAULT_MAX_CONTRACTS=10
DEFAULT_MAX_OPEN_POSITIONS=1
# 12.0 — fixed B3 lot (100 shares); set 0 for risk-based sizing
MOTOR_FIXED_LOT_SHARES=100
STOCK_DAY_LEVERAGE_ASSUMED=50
PAPER_CAPITAL_BRL=1000

# Scanner (daily cron)
SCANNER_CRON_HOUR=8
SCANNER_CRON_MINUTE=30
SCANNER_MIN_VOLUME=5000
SCANNER_MODE=filipe_core5
EXECUTION_BACKEND=ntsl
BACKTEST_MIN_PROFIT_FACTOR=1.3
BACKTEST_MAX_DRAWDOWN_PCT=8.0
SCANNER_INCLUDE_STOCK_OPTIONS=true
SCANNER_SYMBOLS=BOVA11
SCANNER_INCLUDE_BOVA_OPTIONS=true
BOVA_OPTIONS_SYMBOLS=BOVAX125,BOVAY125,BOVA11
# ibov_top20 = scan data/ibov_top20.csv | custom = SCANNER_SYMBOLS only

# Background jobs
ENABLE_SCHEDULER=true
OPTIMIZATION_MAX_WORKERS=2
PAPER_TRADING_MODE=true
JOURNAL_AUTO_ANALYZE=true
JOURNAL_ANALYZE_LIMIT=5

# Alerts (optional — scanner warnings to phone)
ALERTS_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# 3.0 — Structure Deck
MAX_PORTFOLIO_NET_DELTA=0.5
WALK_FORWARD_AUTO_PROMOTE=true
WALK_FORWARD_INTERVAL_HOURS=6
WALK_FORWARD_PROMOTE_FOLDS=4
# Use Profit bridge session candles for WFO when bridge online (else synthetic)
WALK_FORWARD_USE_BRIDGE_CANDLES=false
STRUCTURE_TYPES_ENABLED=scalp,covered_call,vertical,collar,bova_hedge,pair_spread

# Board auth (HTMX blackboard on public VPS)
BOARD_AUTH_ENABLED=false
BOARD_USERNAME=filipe
BOARD_PASSWORD=

# 4.0 GA — autonomy engine (auto confirm/execute per sleeve during B3 hours)
AUTONOMY_ENABLED=false
AUTONOMY_MAX_TRADES_PER_DAY=3
# Paper mode: sleeves ON triggers trading motor (scan + auto confirm/execute)
AUTO_TRADING_ON_SLEEVES=true
ORCHESTRATOR_INTERVAL_SEC=45

# Dashboard login (enable on public VPS)
DASHBOARD_AUTH_ENABLED=false
DASHBOARD_USERNAME=filipe
DASHBOARD_PASSWORD=

# PostgreSQL (docker compose --profile postgres)
POSTGRES_PASSWORD=changeme

# Production reverse proxy (docker --profile proxy)
DOMAIN=trading.dmconsultoria.seg.br

# Cloudflare Tunnel (Windows PC → public HTTPS — docs/cloudflare_tunnel.md)
CLOUDFLARE_TUNNEL_HOSTNAME=trading.dmconsultoria.seg.br
CLOUDFLARE_DASHBOARD_HOSTNAME=dashboard.dmconsultoria.seg.br
CLOUDFLARE_TUNNEL_NAME=arbitragem
# When exposing publicly, set both to true and strong passwords (see .env.tunnel.example)
# BOARD_AUTH_ENABLED=true
# DASHBOARD_AUTH_ENABLED=true

# 7.0 — Golden path (PETR4-only universe when true)
GOLDEN_PATH_MODE=false
# Low-RAM mode — slim caches, no futures/crypto rows, slower motor/SSE (~500 MB budget cap)
# Or: python scripts/dev.py start --wait --low-ram
LOW_RAM_MODE=false
RAM_BUDGET_MB=1200

# 12.0 — crypto deferred (read-only Binance not in active scope)
CRYPTO_WATCHLIST_ENABLED=false
CRYPTO_PAPER_ENABLED=false
BINANCE_QUOTES_ENABLED=false

# Background test worker (spawned by dev.py start; set 0 to disable)
ARBITRAGEM_BG_TESTS=1

# 10.0 — Replay training + strategy store (Eternal Golden Path)
REPLAY_TRAINING_ENABLED=true
REPLAY_TRAINING_INTERVAL_MIN=30
REPLAY_PARALLEL_WORKERS=2
REPLAY_MAX_BARS_PER_SESSION=120
REPLAY_FEED_JOURNAL=true
REPLAY_FEED_WFO=true
REPLAY_OLLAMA_SUMMARY=true
STRATEGY_STORE_ENABLED=true
# PROFITCHART_STRATEGIES_DIR=C:/Nelogica/Profit/Estrategias
STRATEGY_STORE_EXTRA_DIRS=
RESOURCE_RAM_FRACTION=0.8
RESOURCE_GPU_FRACTION=0.4
ENGINE_MIND_ENABLED=true
KNOWLEDGE_ENABLED=true
KNOWLEDGE_MAX_CHUNKS=10000
# KNOWLEDGE_DB_PATH=data/knowledge.db
ARBITRAGEM_BG_REPLAY=1
